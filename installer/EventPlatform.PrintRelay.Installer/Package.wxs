<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <Package
    Name="Event Platform Print Relay"
    Manufacturer="Event Platform"
    Version="$(var.ProductVersion)"
    UpgradeCode="A1B2C3D4-E5F6-7890-ABCD-EF1234567891"
    Scope="perMachine">

    <MajorUpgrade
      DowngradeErrorMessage="A newer version of Event Platform Print Relay is already installed." />
    <MediaTemplate />

    <Feature Id="Main" Title="Print Relay" Level="1">
      <ComponentGroupRef Id="HarvestedComponents" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="AutoStartRegistry" />
    </Feature>

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLROOT" Name="EventPlatform">
        <Directory Id="INSTALLFOLDER" Name="PrintRelay" />
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ApplicationProgramsFolder" Name="Event Platform" />
    </StandardDirectory>

    <Component
      Id="StartMenuShortcut"
      Directory="ApplicationProgramsFolder"
      Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678902"
      Bitness="always64">

      <Shortcut
        Id="ApplicationStartMenuShortcut"
        Name="Print Relay"
        Description="Silent badge printing for Event Platform check-in desks"
        Target="[INSTALLFOLDER]EventPlatform.PrintRelay.exe"
        WorkingDirectory="INSTALLFOLDER" />

      <RemoveFolder Id="CleanUpStartMenuFolder" Directory="ApplicationProgramsFolder" On="uninstall" />

      <RegistryValue
        Root="HKCU"
        Key="Software\EventPlatform\PrintRelay"
        Name="StartMenuInstalled"
        Type="integer"
        Value="1"
        KeyPath="yes" />
    </Component>

    <Component
      Id="AutoStartRegistry"
      Directory="INSTALLFOLDER"
      Guid="C3D4E5F6-A7B8-9012-CDEF-123456789013"
      Bitness="always64">

      <RegistryValue
        Root="HKCU"
        Key="Software\Microsoft\Windows\CurrentVersion\Run"
        Name="EventPlatform.PrintRelay"
        Type="string"
        Value="&quot;[INSTALLFOLDER]EventPlatform.PrintRelay.exe&quot;"
        KeyPath="yes" />

      <CreateFolder />
    </Component>

  </Package>

</Wix>
